# ============================================
# TCL智能产品咨询助手 - 环境变量配置示例
# ============================================

# ------------------------------
# GLM API配置
# ------------------------------
# 默认API密钥已配置，可直接使用
# 如需更换，请访问 https://open.bigmodel.cn/ 注册并获取新的API密钥
ZHIPUAI_API_KEY=967bf1087dbc4faca0c8286443b5d7a5.Oys89JDnjgfe86ja

# ------------------------------
# 模型配置
# ------------------------------
# 可选模型：glm-4.5-air, glm-4.7-flash
# 推荐使用 glm-4.5-air，稳定性和响应速度最优
MODEL_NAME=glm-4.5-air
# MODEL_NAME=glm-4.7-flash    # 最新模型，性能更强

# ------------------------------
# LLM参数配置
# ------------------------------
MAX_TOKENS=2000              # 最大输出token数
TEMPERATURE=0.7              # 生成温度（0-1，越小越确定）
TOP_P=0.9                    # 核采样

# ------------------------------
# 日志配置
# ------------------------------
LOG_LEVEL=INFO               # DEBUG, INFO, WARNING, ERROR

# ------------------------------
# RAG检索配置
# ------------------------------
CHUNK_SIZE=500               # 文档切片大小
CHUNK_OVERLAP=50             # 切片重叠大小
TOP_K_RETRIEVAL=3            # 检索返回条数

# ------------------------------
# 缓存配置
# ------------------------------
CACHE_MAX_SIZE=100           # 缓存最大条数
CACHE_TTL_SECONDS=300        # 缓存过期时间（秒）

# ------------------------------
# 对话配置
# ------------------------------
MAX_HISTORY_LENGTH=20        # 最大对话历史长度

# ------------------------------
# 代理配置（如需要访问HuggingFace）
# ------------------------------
# HTTP_PROXY=http://127.0.0.1:12334
# HTTPS_PROXY=http://127.0.0.1:12334
# HF_ENDPOINT=https://hf-mirror.com